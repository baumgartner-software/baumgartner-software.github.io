<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{Astro.props.title}</title>
    <style>
      body {
        font-family: sans-serif;
        margin: 0;
        background-color: #f5f5f5;
      }
      header {
        background-color: #0F4C81;
        color: #fff;
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      header img {
        height: 50px;
        margin-right: 1rem;
      }
      header nav a {
        color: white;
        margin-left: 1rem;
        text-decoration: none;
      }
      main {
        max-width: 800px;
        margin: 2rem auto;
        padding: 0 1rem;
        background: white;
        box-shadow: 0 0 10px rgba(0,0,0,.1);
      }
      footer {
        text-align: center;
        padding: 2rem 0;
        color: #777;
        font-size: 0.9rem;
      }
    </style>
  </head>
  <body>
    <header>
      <div style="display:flex;align-items:center;">
        <img src="/logo.svg" alt="Baumgartner Software Logo" />
        <div>
          <div style="font-size:1.5rem;font-weight:bold;">Baumgartner-Software</div>
          <div style="font-size:0.9rem;">IDEEN. WACHSEN. LASSEN.</div>
        </div>
      </div>
      <nav>
        <a href="/">Home</a>
        <a href="/impressum">Impressum</a>
        <a href="/kontakt">Kontakt</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>&copy; {new Date().getFullYear()} Baumgartner-Software</footer>
  </body>
</html>
